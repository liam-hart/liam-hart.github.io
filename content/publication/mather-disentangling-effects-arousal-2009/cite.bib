 doi = {10.1177/1754073908100435},
 file = {/Users/Liam1/Zotero/storage/B2DLMYGF/Mather-2009-Disentangling the effects of arou1.pdf},
 issn = {1754-0739, 1754-0747},
 journal = {Emotion Review},
