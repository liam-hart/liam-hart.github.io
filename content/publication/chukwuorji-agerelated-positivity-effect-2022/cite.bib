@article{chukwuorjiAgerelatedPositivityEffect2022,
 abstract = {While substantial literature suggests that positive preferences are in the service of emotion regulation pursuits, little evidence has directly linked positivity ``processes'' with well-being ``outcomes.'' The current study examined age-related differences in negative gaze preferences and how such preferences are related to subsequent regulatory outcomes. Participants were 79 older adults and 72 younger adults. They first provided a baseline mood assessment, which was followed by a standardized emotional video clip for three minutes during which visual fixation preferences were recorded via an eye tracker. Mood was again assessed after the film, which was followed by a standardized video recovery task, and completion of a recovery mood measure. Older adults fixated less on negative portions of the emotional video clip relative to younger adults, indicative of an age-related positivity effect. The indirect effect of age on mood recovery through fixation was not supported.},
 annotation = {3 citations (Crossref/DOI) [2025-05-21]\\
3 citations (Crossref/DOI) [2025-04-09]\\
3 citations (Crossref/DOI) [2025-04-08]},
 author = {Chukwuorji, JohnBosco Chika and Allard, Eric S.},
 doi = {10.1177/00914150221077954},
 file = {/Users/Liam1/Zotero/storage/UEQJBYPC/Chukwuorji-2022-The age-related positivity eff.pdf},
 issn = {0091-4150, 1541-3535},
 journal = {International Journal of Aging and Human Development},
 langid = {english},
 month = {December},
 number = {4},
 pages = {455--469},
 shorttitle = {The Age-Related Positivity Effect and Emotion Regulation},
 title = {The Age-Related Positivity Effect and Emotion Regulation: Assessing Downstream Affective Outcomes},
