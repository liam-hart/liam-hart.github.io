@article{steinerLifeStoryChapters2017,
 abstract = {Summary             Two studies investigated the effects of recalling either life story chapters or specific memories on measures of self-continuity and self-esteem. Participants were assigned to recall important chapters, important specific memories, or impersonal facts, and they provided ratings of emotional tone. Participants also completed trait and state measures of self-continuity, self-esteem, and mood. Although effects of recall condition on state and trait measures were not statistically significant, within-group analyses identified strong and consistent relationships between the positivity of life story chapters and both trait and state self-continuity and self-esteem. In contrast, the positivity of specific memories was related only to state self-esteem. Qualities of life story chapters appear to be more central to enduring conceptions of the self than do qualities of specific life story memories.Copyright o̧pyright 2017 John Wiley & Sons, Ltd.},
