 month = {January},
 number = {1},
 pages = {1--12},
 shorttitle = {A Comparison of Flashbacks and Ordinary Autobiographical Memories of Trauma},
 title = {A Comparison of Flashbacks and Ordinary Autobiographical Memories of Trauma: Content and Language},
