 file = {/Users/Liam1/Zotero/storage/N6SQPBTS/Spreng-2010-Patterns of brain activity suppor1.pdf},
 issn = {0898-929X, 1530-8898},
 journal = {Journal of Cognitive Neuroscience},
 langid = {english},
 month = {June},
