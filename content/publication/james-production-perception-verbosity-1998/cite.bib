 author = {James, Lori E. and Burke, Deborah M. and Austin, Ayda and Hulme, Erika},
 doi = {10.1037/0882-7974.13.3.355},
 file = {/Users/Liam1/Zotero/storage/INPG8U9C/James-1998-Production and perception of _verbo.pdf},
 issn = {1939-1498, 0882-7974},
 journal = {Psychology and Aging},
 langid = {english},
