 author = {Cook Maher, Amanda and Kielb, Stephanie and Loyer, Emmaleigh and Connelley, Maureen and Rademaker, Alfred and Mesulam, M.-Marsel and Weintraub, Sandra and McAdams, Dan and Logan, Regina and Rogalski, Emily},
 doi = {10.1371/journal.pone.0186413},
