 shorttitle = {The Centrality of Event Scale},
 title = {The Centrality of Event Scale: A Measure of Integrating a Trauma into One's Identity and Its Relation to Post-Traumatic Stress Disorder Symptoms},
 urldate = {2025-04-08},
