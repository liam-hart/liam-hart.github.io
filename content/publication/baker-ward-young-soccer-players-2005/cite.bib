 file = {/Users/Liam1/Zotero/storage/MQZU9VDM/Baker-Ward-2005-Young Soccer Players' Reports.pdf},
 issn = {1524-8372, 1532-7647},
 journal = {Journal of Cognition and Development},
 langid = {english},
 month = {November},
 number = {4},
 pages = {507--527},
 shorttitle = {Young Soccer Players' Reports of a Tournament Win or Loss},
 title = {Young Soccer Players' Reports of a Tournament Win or Loss: Different Emotions, Different Narratives},
