 issn = {10538100},
 journal = {Consciousness and Cognition},
 langid = {english},
 month = {May},
 pages = {145--155},
 shorttitle = {A Matter of Focus},
 title = {A Matter of Focus: Detailed Memory in the Intentional Autobiographical Recall of Older and Younger Adults},
