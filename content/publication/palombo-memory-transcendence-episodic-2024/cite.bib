 issn = {11961961},
 journal = {Canadian Journal Of Experimental Psychology},
 keywords = {/unread,Autobiographical Memory,Cognition & reasoning,Episodic Memory,Meaning,Memory,Metacognition,Narratives,Older people,Semantics,Storytelling},
