 abstract = {Public Significance Statement Humans tell stories of their past through episodic remembering, wherein one recalls events they have experienced, be it a walk through the park, or a harrowing car crash. A proclivity for human storytelling is evident in communication, ceremony, and ritual throughout the lifespan. [...]a range of artistic mediums-from literature, to plays, to movies-feature storytelling. Episodic Narratives and Memory Intuitively, memories are records of the past and, indeed, many researchers (including the author) study episodic narratives to learn about how much one can remember about a given event. Studies of episodic narratives reveal important patterns of spared, impaired, and/or differential recollection in a range of populations, including patients with brain lesions (Dede et al., 2016; Kopelman et al., 1989; Race et al., 2011; Rosenbaum et al., 2009), neurological disease (Addis & Tippett, 2004; Berntsen et al., 2022; Irish, 2023; also see Simpson et al., 2023), mental health conditions (McKinnon et al., 2015; Rubin, 2011; Sôderlund et al., 2014), in aging (Devitt et al., 2017; Levine et al., 2002; Simpson et al., 2023; also see Martin et al., 2022) or in relation to individual differences (Dawes et al., 2022; Palombo et al., 2018; also see Rubin, 2021).},
 address = {Ottawa, Canada},
 author = {Palombo, Daniela J.},
 copyright = {Copyright Canadian Psychological Association Sep 2024},
