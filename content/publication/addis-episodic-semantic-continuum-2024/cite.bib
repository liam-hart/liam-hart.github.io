 pages = {20230408},
 publisher = {Royal Society},
 shorttitle = {Beyond the Episodic--Semantic Continuum},
 title = {Beyond the Episodic--Semantic Continuum: The Multidimensional Model of Mental Representations},
 urldate = {2025-04-15},
