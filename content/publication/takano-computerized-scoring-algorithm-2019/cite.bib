 shorttitle = {The Computerized Scoring Algorithm for the Autobiographical Memory Test},
 title = {The Computerized Scoring Algorithm for the Autobiographical Memory Test: Updates and Extensions for Analyzing Memories of English-Speaking Adults},
 urldate = {2025-04-08},
