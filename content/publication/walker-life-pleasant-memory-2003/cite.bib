 doi = {10.1037/1089-2680.7.2.203},
 file = {/Users/Liam1/Zotero/storage/98VZGYV9/Walker-2003-Life is Pleasant—and Memory Helps.pdf},
 issn = {1089-2680, 1939-1552},
 journal = {Review of General Psychology},
 langid = {english},
