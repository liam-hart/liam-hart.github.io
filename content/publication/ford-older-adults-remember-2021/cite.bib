@article{fordOlderAdultsRemember2021,
 abstract = {The initial phase of the coronavirus disease 2019 (COVID-19) pandemic changed our lives dramatically, with stay-at-home orders and extreme physical distancing requirements. The present study suggests that how adults remember these disruptions depends, in part, on their age. In two surveys collected from American and Canadian participants during Summer 2020 (n = 551) and Fall 2020 (n = 506), older age (across ages 18-90 years) was associated with greater reflections on positive aspects of the initial phase of the pandemic. While the pandemic is a shared experience, the way it is remembered may differ across generations, with older age leading to a greater focus on the positive aspects. (PsycInfo Database Record (c) 2021 APA, all rights reserved).},
