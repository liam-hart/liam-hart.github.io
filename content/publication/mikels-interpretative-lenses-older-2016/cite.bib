 shorttitle = {The Interpretative Lenses of Older Adults Are Not Rose-Colored---Just Less Dark},
 title = {The Interpretative Lenses of Older Adults Are Not Rose-Colored---Just Less Dark: Aging and the Interpretation of Ambiguous Scenarios},
