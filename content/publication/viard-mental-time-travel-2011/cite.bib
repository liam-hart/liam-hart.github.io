97 citations (Crossref/DOI) [2025-04-08]},
 author = {Viard, Armelle and Chételat, Gaël and Lebreton, Karine and Desgranges, Béatrice and Landeau, Brigitte and De La Sayette, Vincent and Eustache, Francis and Piolino, Pascale},
