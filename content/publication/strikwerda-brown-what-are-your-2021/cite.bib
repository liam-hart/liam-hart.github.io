 pages = {1375--1383},
 shorttitle = {What Are Your Thoughts?},
 title = {What Are Your Thoughts? Exploring Age-Related Changes in Episodic and Semantic Autobiographical Content on an Open-Ended Retrieval Task},
 urldate = {2025-04-08},
