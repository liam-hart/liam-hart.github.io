 doi = {10.1037/0096-3445.117.4.371},
 file = {/Users/Liam1/Zotero/storage/8YEJJRMH/Johnson et al. - 1988 - Phenomenal characteristics of memories for perceived and imagined autobiographical events..pdf},
 issn = {0096-3445},
 journal = {Journal of Experimental Psychology: General},
 keywords = {/unread,Adulthood (18 yrs & older),Early Memories,Experiences (Events),Long Term Memory,Reality Testing},
