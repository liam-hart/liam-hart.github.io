 issn = {1939-1498, 0882-7974},
 journal = {Psychology and Aging},
 langid = {english},
 number = {3},
 pages = {331--338},
 shorttitle = {Social and Emotional Patterns in Adulthood},
 title = {Social and Emotional Patterns in Adulthood: Support for Socioemotional Selectivity Theory},
 urldate = {2025-04-08},
