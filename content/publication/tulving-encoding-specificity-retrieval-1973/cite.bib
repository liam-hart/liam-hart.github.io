 file = {/Users/Liam1/Zotero/storage/J7P5IV7H/Tulving-1973-Encoding specificity and retrieva.pdf},
 issn = {1939-1471, 0033-295X},
 journal = {Psychological Review},
 langid = {english},
 month = {September},
 number = {5},
 pages = {352--373},
 title = {Encoding Specificity and Retrieval Processes in Episodic Memory},
 urldate = {2025-04-08},
