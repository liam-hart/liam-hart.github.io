 doi = {10.3758/s13428-024-02440-1},
 file = {/Users/Liam1/Zotero/storage/FNWK7U8J/Pfeifer-2024-How ready is speech-to-text for p.pdf},
 issn = {1554-3528},
 journal = {Behavior Research Methods},
