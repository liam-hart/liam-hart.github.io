 issn = {1662-9647, 1662-971X},
 journal = {Geropsych},
 langid = {english},
 month = {March},
 number = {1},
 pages = {15--29},
 title = {Interindividual Differences in Cognitive Functioning Are Associated with Autobiographical Memory Retrieval Specificity in Older Adults},
