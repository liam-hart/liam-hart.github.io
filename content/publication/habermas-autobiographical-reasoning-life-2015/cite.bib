 author = {Habermas, Tilmann and Köber, Christin},
 doi = {10.1080/09658211.2014.920885},
 file = {/Users/Liam1/Zotero/storage/LATLBFEJ/Habermas-2015-Autobiographical reasoning in li.pdf},
 issn = {0965-8211, 1464-0686},
 journal = {Memory},
