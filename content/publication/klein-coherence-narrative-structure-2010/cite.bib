 issn = {0736-7236},
 journal = {Journal of Social and Clinical Psychology},
 langid = {english},
 month = {March},
 number = {3},
 pages = {256--280},
 title = {Coherence and Narrative Structure in Personal Accounts of Stressful Experiences},
