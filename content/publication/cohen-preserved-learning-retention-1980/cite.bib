 issn = {0036-8075, 1095-9203},
 journal = {Science},
 langid = {english},
 month = {October},
 number = {4466},
 pages = {207--210},
 shorttitle = {Preserved Learning and Retention of Pattern-Analyzing Skill in Amnesia},
 title = {Preserved Learning and Retention of Pattern-Analyzing Skill in Amnesia: Dissociation of Knowing How and Knowing That},
 urldate = {2025-04-08},
 volume = {210},
 year = {1980}
}
