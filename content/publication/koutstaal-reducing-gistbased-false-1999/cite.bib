@article{koutstaalReducingGistbasedFalse1999,
 abstract = {Using a categorized pictures paradigm, Koutstaal and Schacter (1997) reported high levels of false recognition of lures that were categorically related to presented items. Although also shown by younger adults, false recognition was markedly higher for older adults. To probe the factors underlying this age difference, these experiments required participants to engage in more careful scrutiny of the items at retrieval or to notice specific differentiating perceptual features of the objects during encoding. False recognition was reduced with each of these manipulations, but neither manipulation, either separately or together, eliminated the age difference in false recognition. Older adults can considerably reduce false recognition if encouraged to use more stringent decision criteria. Persistent difficulty in opposing familiarity-based responding and comparatively more generic encoding may contribute to residual deficits.},
 annotation = {98 citations (Crossref/DOI) [2025-05-21]\\
97 citations (Crossref/DOI) [2025-04-09]\\
97 citations (Crossref/DOI) [2025-04-08]},
 author = {Koutstaal, Wilma and Schacter, Daniel L. and Galluccio, Lissa and Stofer, Kathryn A.},
 doi = {10.1037/0882-7974.14.2.220},
 file = {/Users/Liam1/Zotero/storage/3PI84T4T/Koutstaal-1999-Reducing gist-based false recog.pdf},
 issn = {1939-1498, 0882-7974},
 journal = {Psychology and Aging},
 langid = {english},
 number = {2},
 pages = {220--237},
 shorttitle = {Reducing Gist-Based False Recognition in Older Adults},
 title = {Reducing Gist-Based False Recognition in Older Adults: Encoding and Retrieval Manipulations},
