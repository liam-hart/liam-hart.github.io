 pages = {2462--2476},
 shorttitle = {Prefrontal Engagement and Reduced Default Network Suppression Co-occur and Are Dynamically Coupled in Older Adults},
 title = {Prefrontal Engagement and Reduced Default Network Suppression Co-occur and Are Dynamically Coupled in Older Adults: The Default--Executive Coupling Hypothesis of Aging},
