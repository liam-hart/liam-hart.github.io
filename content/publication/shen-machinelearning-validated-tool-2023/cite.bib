@article{shenMachinelearningValidatedTool2023,
 abstract = {The use of naturalistic stimuli, such as narrative movies, is gaining popularity in many fields, characterizing memory, affect, and decision-making. Narrative recall paradigms are often used to capture the complexity and richness of memory for naturalistic events. However, scoring narrative recalls is time-consuming and prone to human biases. Here, we show the validity and reliability of using a natural language processing tool, the Universal Sentence Encoder (USE), to automatically score narrative recalls. We compared the reliability in scoring made between two independent raters (i.e., hand scored) and between our automated algorithm and individual raters (i.e., automated) on trial-unique video clips of magic tricks. Study 1 showed that our automated segmentation approaches yielded high reliability and reflected measures yielded by hand scoring. Study 1 further showed that the results using USE outperformed another popular natural language processing tool, GloVe. In Study 2, we tested whether our automated approach remained valid when testing individuals varying on clinically relevant dimensions that influence episodic memory, age, and anxiety. We found that our automated approach was equally reliable across both age groups and anxiety groups, which shows the efficacy of our approach to assess narrative recall in large-scale individual difference analysis. In sum, these findings suggested that machine learning approach implementing USE is a promising tool for scoring large-scale narrative recalls and perform individual difference analysis for research using naturalistic stimuli.},
 annotation = {4 citations (Crossref/DOI) [2025-05-21]\\
4 citations (Crossref/DOI) [2025-04-09]\\
4 citations (Crossref/DOI) [2025-04-08]},
 author = {Shen, Xinxu and Houser, Troy and Smith, David V. and Murty, Vishnu P.},
 doi = {10.3758/s13423-022-02171-4},
 file = {/Users/Liam1/Zotero/storage/32AQX3WV/Shen-2023-Machine-learning as a validated tool.pdf},
 issn = {1069-9384, 1531-5320},
 journal = {Psychonomic Bulletin & Review},
 langid = {english},
 month = {February},
 number = {1},
 pages = {308--316},
 title = {Machine-Learning as a Validated Tool to Characterize Individual Differences in Free Recall of Naturalistic Events},
 urldate = {2025-04-08},
