 author = {Carstensen, Laura L. and Fung, Helene H. and Charles, Susan T.},
 doi = {10.1023/A:1024569803230},
 file = {/Users/Liam1/Zotero/storage/XFKL7N9E/Carstensen-2003-Socioemotional Selectivity Th1.pdf},
 issn = {01467239},
 journal = {Motivation and Emotion},
 langid = {english},
 number = {2},
 pages = {103--123},
 title = {Socioemotional Selectivity Theory and the Regulation of Emotion in the Second Half of Life1},
