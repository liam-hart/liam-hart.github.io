 doi = {10.1016/j.concog.2004.07.007},
 file = {/Users/Liam1/Zotero/storage/ISMQD8WL/D'Argembeau-2004-Phenomenal characteristics as.pdf},
 issn = {10538100},
 journal = {Consciousness and Cognition},
 langid = {english},
