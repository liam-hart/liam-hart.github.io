 doi = {10.1016/j.brat.2006.02.004},
 file = {/Users/Liam1/Zotero/storage/HDCISNVL/Jones-2007-The organisation and content of tra.pdf},
 issn = {00057967},
 journal = {Behaviour Research and Therapy},
