 issn = {0954-0261, 1369-1627},
 journal = {International Review of Psychiatry},
 langid = {english},
 month = {July},
 number = {4},
 pages = {331--342},
 shorttitle = {Awe},
 title = {Awe: A Putative Mechanism Underlying the Effects of Classic Psychedelic-Assisted Psychotherapy},
