 issn = {0965-8211, 1464-0686},
 journal = {Memory},
 keywords = {/unread,Episodic memory,Female,Humans,imagery,Imagination,individual differences,Individuality,Male,Memory Episodic,Photic Stimulation,Reaction Time,Spatial Memory,Visual Perception,Young Adult},
