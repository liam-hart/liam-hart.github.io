 doi = {10.1016/j.tins.2011.06.006},
 file = {/Users/Liam1/Zotero/storage/KHEHGP2E/Yassa-2011-Pattern separation in the hippocamp.pdf},
 issn = {01662236},
 journal = {Trends in Neurosciences},
 langid = {english},
