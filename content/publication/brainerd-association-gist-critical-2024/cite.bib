 file = {/Users/Liam1/Zotero/storage/TSNP8444/Brainerd et al. - 2024 - From association to gist Some critical tests.pdf;/Users/Liam1/Zotero/storage/TJAGL28H/doiLanding.html},
 issn = {1939-1285},
 journal = {Journal of Experimental Psychology: Learning, Memory, and Cognition},
 keywords = {/unread,Associative Processes,associative strength,DRM illusion,Dual Process Models,dual-retrieval model,False Memory,gist strength,Human Information Storage,Illusions (Perception)},
