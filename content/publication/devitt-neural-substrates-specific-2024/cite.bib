 doi = {10.1016/j.neuropsychologia.2023.108754},
 file = {/Users/Liam1/Zotero/storage/QNFIB7YF/Devitt et al. - 2024 - Neural substrates of specific and general autobiographical memory retrieval in younger and older adu.pdf;/Users/Liam1/Zotero/storage/84A6C98Q/S0028393223002889.html},
