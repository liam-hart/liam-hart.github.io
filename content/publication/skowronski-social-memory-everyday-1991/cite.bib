 doi = {10.1037/0022-3514.60.6.831},
 file = {/Users/Liam1/Zotero/storage/8DKHM6JY/Skowronski et al. - 1991 - Social memory in everyday life Recall of self-events and other-events.pdf},
 issn = {1939-1315},
 journal = {Journal of Personality and Social Psychology},
 keywords = {Expectations,Experiences (Events),Human Sex Differences,Memory,Pleasure,Time},
