 doi = {10.1073/pnas.2221919120},
 file = {/Users/Liam1/Zotero/storage/QD9DF4N5/Rouhani-2023-Collective events and individual.pdf},
 issn = {0027-8424, 1091-6490},
 journal = {Proceedings of the National Academy of Sciences},
