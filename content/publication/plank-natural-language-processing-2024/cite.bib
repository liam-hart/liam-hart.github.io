 file = {/Users/Liam1/Zotero/storage/P97WPN2P/Plank and Zlomuzica - 2024 - Natural language processing reveals differences in mental time travel at higher levels of self-effic.pdf},
 issn = {2045-2322},
 journal = {Scientific Reports},
 langid = {english},
