 copyright = {http://www.springer.com/tdm},
 doi = {10.3758/BF03197278},
 file = {/Users/Liam1/Zotero/storage/XLMHEYH9/Williams-1996-The specificity of autobiographi.pdf},
 issn = {0090-502X, 1532-5946},
 journal = {Memory & Cognition},
 langid = {english},
 month = {January},
 number = {1},
 pages = {116--125},
 title = {The Specificity of Autobiographical Memory and Imageability of the Future},
