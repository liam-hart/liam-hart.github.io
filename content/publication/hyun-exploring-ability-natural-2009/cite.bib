@article{hyunExploringAbilityNatural2009,
 abstract = {Natural Language Processing (NLP) offers an approach for capturing data from narratives and creating structured reports for further computer processing. We explored the ability of a NLP system, Medical Language Extraction and Encoding (MedLEE), on nursing narratives. MedLEE extracted 490 concepts from narrative text in a sample of 553 oncology nursing process notes. The most frequently monitored and recorded signs and symptoms were related to chemotherapy care, such as adverse reactions, shortness of breath, nausea, pain, and bleeding. In terms of nursing interventions, chemotherapy, blood culture, medication, and blood transfusion were commonly recorded in free text. NLP may provide a feasible approach to extract data related to patient safety/quality measures and nursing outcomes by capturing nursing concepts that are not recorded through structured data entry. For better NLP performance in the domain of nursing, additional nursing terms and abbreviations must be added to MedLEE's lexicon.},
 annotation = {41 citations (Crossref/DOI) [2025-05-23]},
 author = {Hyun, Sookyung and Johnson, Stephen B. and Bakken, Suzanne},
 doi = {10.1097/NCN.0b013e3181a91b58},
 file = {/Users/Liam1/Zotero/storage/QIWZYLDR/Hyun et al. - 2009 - Exploring the Ability of Natural Language Processing to Extract Data From Nursing Narratives.pdf},
 issn = {1538-2931},
 journal = {CIN: Computers, Informatics, Nursing},
 keywords = {/unread},
 langid = {english},
 month = {July},
 pages = {215--223},
 shorttitle = {Exploring the Ability of Natural Language Processing to Extract Data From Nursing Narratives},
 title = {Exploring the Ability of Natural Language Processing to Extract Data From Nursing Narratives:},
 urldate = {2025-05-23},
 year = {2009}
}
