 pages = {438--450},
 shorttitle = {When Trying to Recall Our Past, All Roads Lead to Rome},
 title = {When Trying to Recall Our Past, All Roads Lead to Rome: More Evidence for the Multi-Process Retrieval Theory of Autobiographical Memory},
