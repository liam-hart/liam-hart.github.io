75 citations (Crossref/DOI) [2025-04-08]},
 author = {Irish, Muireann and Addis, Donna Rose and Hodges, John R. and Piguet, Olivier},
 copyright = {https://www.elsevier.com/tdm/userlicense/1.0/},
 doi = {10.1016/j.neuropsychologia.2012.09.012},
 file = {/Users/Liam1/Zotero/storage/FZCWLBSE/Irish-2012-Exploring the content and quality o.pdf},
 issn = {00283932},
 journal = {Neuropsychologia},
