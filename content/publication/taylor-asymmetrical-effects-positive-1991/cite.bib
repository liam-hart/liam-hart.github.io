 issn = {1939-1455, 0033-2909},
 journal = {Psychological Bulletin},
 langid = {english},
 number = {1},
 pages = {67--85},
 shorttitle = {Asymmetrical Effects of Positive and Negative Events},
 title = {Asymmetrical Effects of Positive and Negative Events: The Mobilization-Minimization Hypothesis},
 urldate = {2025-04-08},
 volume = {110},
