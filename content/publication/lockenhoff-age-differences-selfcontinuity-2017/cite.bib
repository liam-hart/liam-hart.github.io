40 citations (Crossref/DOI) [2025-04-08]},
 author = {Löckenhoff, Corinna E. and Rutt, Joshua L.},
 doi = {10.1093/geront/gnx010},
 file = {/Users/Liam1/Zotero/storage/LIRPMSZV/Lockenhoff-2017-Age Differences in Self-Contin.pdf},
 issn = {0016-9013, 1758-5341},
 journal = {Gerontologist},
