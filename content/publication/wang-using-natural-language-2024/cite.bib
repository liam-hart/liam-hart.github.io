 author = {Wang, Yilei and Tian, Jingyuan and Yazar, Yagizhan and Ones, Deniz S. and Landers, Richard N.},
 doi = {10.1037/met0000518},
 file = {/Users/Liam1/Zotero/storage/6WP4GI3D/Wang-2022-Using natural language processing an.pdf},
 issn = {1939-1463, 1082-989X},
