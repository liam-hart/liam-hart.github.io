 author = {Chiu, Connie P.Y. and Griffith, James W. and Lenaert, Bert and Raes, Filip and Hermans, Dirk and Barry, Tom J.},
 doi = {10.1080/09658211.2018.1474928},
 file = {/Users/Liam1/Zotero/storage/DLVNL2XJ/Chiu-2018-Meta-analysis of the association bet.pdf},
 issn = {0965-8211, 1464-0686},
