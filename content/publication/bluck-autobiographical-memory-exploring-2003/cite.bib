@article{bluckAutobiographicalMemoryExploring2003,
 abstract = {This special issue of Memory spotlights research that uses a functional approach to investigate autobiographical memory (AM) in everyday life. This approach relies on studying cognition, in this case AM, taking into account the psychological, social, or cultural-historic context in which it occurs. Areas of interest include understanding to what ends AM is used by individuals and in social relationships, how it is related to other cognitive abilities and emotional states, and how memory represents our inner and outer world. One insight gained by taking this approach is that levels and types of accuracy need not always be regarded as memory "failures" but are sometimes integral to a self-memory system that serves a variety of meaningful ends of human activity. Previously hypothesised functions of AM fall into three broad domains: self, social, and directive. Each of the contributions addresses how AM serves one or more of these functions and thereby examines the usefulness and adequacy of this trio.},
 annotation = {334 citations (Crossref/DOI) [2025-05-21]\\
