@article{reuter-lorenzBrainAgingReorganizing2005,
 abstract = {New discoveries challenge the long-held view that aging is characterized by progressive loss and decline. Evidence for functional reorganization, compensation and effective interventions holds promise for a more optimistic view of neurocognitive status in later life. Complexities associated with assigning function to age-specific activation patterns must be considered relative to performance and in light of pathological aging. New biological and genetic markers, coupled with advances in imaging technologies, are enabling more precise characterization of healthy aging. This interdisciplinary, cognitive neuroscience approach reveals dynamic and optimizing processes in aging that might be harnessed to foster the successful aging of the mind.},
