 file = {/Users/Liam1/Zotero/storage/69HJ2RBM/Wardell et al. - 2021 - How emotion influences the details recalled in autobiographical memory.pdf;/Users/Liam1/Zotero/storage/Q6WRKJ28/Wardell-2021-How emotion influences the detail.pdf},
