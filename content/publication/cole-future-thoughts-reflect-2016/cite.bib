 issn = {1747-0218, 1747-0226},
 journal = {Quarterly Journal of Experimental Psychology},
 langid = {english},
 month = {February},
 number = {2},
 pages = {273--284},
 shorttitle = {Do Future Thoughts Reflect Personal Goals?},
 title = {Do Future Thoughts Reflect Personal Goals? Current Concerns and Mental Time Travel into the Past and Future},
