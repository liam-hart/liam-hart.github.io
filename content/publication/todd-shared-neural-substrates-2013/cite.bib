 author = {Todd, Rebecca M. and Schmitz, Taylor W. and Susskind, Josh and Anderson, Adam K.},
 doi = {10.3389/fnbeh.2013.00040},
 file = {/Users/Liam1/Zotero/storage/ZN7VV3JS/Todd-2013-Shared neural substrates of emotiona.pdf},
 issn = {1662-5153},
 journal = {Frontiers in Behavioral Neuroscience},
 langid = {english},
