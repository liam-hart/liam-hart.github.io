@article{joormannMemoryAccessibilityMood2004,
 abstract = {Recent studies have suggested that mood-incongruency effects are due to mood-regulatory processes, in which people retrieve positive memories to repair negative moods. In Study 1, the authors investigated whether dysphoria influences the accessibility of autobiographical memories following a positive or a negative mood induction combined with subsequent rumination or distraction. The results showed a mood-repair effect for nondysphoric but not for dysphoric participants following rumination. In Study 2, participants were asked to either distract themselves or to recall positive autobiographical memories after a negative mood induction. Whereas nondysphoric participants' mood improved under both conditions, dysphoric participants' mood improved only after distraction. These results suggest that dysphoria is associated with a reduced ability to use mood-incongruent recall to repair sad moods.},
 annotation = {237 citations (Crossref/DOI) [2025-05-21]\\
237 citations (Crossref/DOI) [2025-04-09]\\
237 citations (Crossref/DOI) [2025-04-08]},
 author = {Joormann, Jutta and Siemer, Matthias},
 doi = {10.1037/0021-843X.113.2.179},
 file = {/Users/Liam1/Zotero/storage/B2REJJQA/Joormann-2004-Memory accessibility, mood regul.pdf},
 issn = {1939-1846, 0021-843X},
 journal = {Journal of Abnormal Psychology},
 langid = {english},
 month = {May},
 number = {2},
 pages = {179--188},
 shorttitle = {Memory Accessibility, Mood Regulation, and Dysphoria},
 title = {Memory Accessibility, Mood Regulation, and Dysphoria: Difficulties in Repairing Sad Mood with Happy Memories?},
 urldate = {2025-04-08},
 volume = {113},
 year = {2004}
}
