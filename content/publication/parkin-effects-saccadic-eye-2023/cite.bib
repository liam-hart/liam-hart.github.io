4 citations (Crossref/DOI) [2025-04-08]},
 author = {Parkin, Adam and Parker, Andrew and Dagnall, Neil},
 doi = {10.1080/09658211.2022.2122997},
 file = {/Users/Liam1/Zotero/storage/ZYF46Y7U/Parkin-2023-Effects of saccadic eye movements.pdf},
 issn = {0965-8211, 1464-0686},
