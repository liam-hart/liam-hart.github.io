 doi = {10.3758/s13421-012-0260-y},
 file = {/Users/Liam1/Zotero/storage/3DJVGW8Y/Rasmussen-2013-The reality of the past versus.pdf},
 issn = {0090-502X, 1532-5946},
 journal = {Memory & Cognition},
