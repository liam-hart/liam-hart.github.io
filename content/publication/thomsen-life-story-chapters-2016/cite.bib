@article{thomsenLifeStoryChapters2016,
 abstract = {People think of their lives as consisting of chapters (e.g., "my childhood", "my school years", "when I lived in New York"). New studies show that people also think of their future lives and other people's lives as consisting of chapters. When individuals grow older, they imagine fewer and less temporally extended future chapters and may thus perceive their future as limited. People who think of their lives in terms of more positive past and future chapters experience greater well-being. In addition, individuals who describe their own life chapters as positive also believe that their friends have positive life chapters, suggesting that the way individuals think of their own and close others' lives may be similar. These new studies suggest that our ability to think of our lives as consisting of chapters may be tied to our sense of time, our well-being and our understanding of other people.},
 annotation = {25 citations (Crossref/DOI) [2025-05-21]\\
25 citations (Crossref/DOI) [2025-04-09]\\
