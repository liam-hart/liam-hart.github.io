 doi = {10.3758/PBR.15.1.191},
 file = {/Users/Liam1/Zotero/storage/QLRSQY82/Tomaszczyk-2008-Personal relevance modulates t.pdf},
 issn = {1069-9384, 1531-5320},
 journal = {Psychonomic Bulletin & Review},
