 doi = {10.1080/09658210802010497},
 file = {/Users/Liam1/Zotero/storage/FTUP8Z8B/Thomsen-2008-The cultural life script and life.pdf},
 issn = {0965-8211, 1464-0686},
 journal = {Memory},
