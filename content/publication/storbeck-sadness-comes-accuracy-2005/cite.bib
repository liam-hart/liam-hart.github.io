 doi = {10.1111/j.1467-9280.2005.01615.x},
 file = {/Users/Liam1/Zotero/storage/GR7P2ZIR/Storbeck-2005-With sadness comes accuracy; wit.pdf},
 issn = {0956-7976, 1467-9280},
 journal = {Psychological Science},
 langid = {english},
 month = {October},
